{
  "name": "bi-template",
  "version": "0.1.0",
  "description": "BGP BI template — clone para criar BI de cliente novo",
  "templateVersion": "1.1.0",
  "private": true,
  "scripts": {
    "init": "node bgp-bi.cjs init",
    "fetch": "node fetch-data.cjs",
    "fetch:fat": "node fetch-pedidos.cjs",
    "fetch:fat:clean": "node fetch-pedidos.cjs --no-cache",
    "build": "node bgp-bi.cjs build",
    "publish": "node bgp-bi.cjs publish",
    "sync": "node bgp-bi.cjs sync"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "esbuild": "^0.21.0",
    "xlsx": "^0.18.5"
  },
  "engines": {
    "node": ">=18"
  }
}
